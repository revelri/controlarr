    { "path": "packages/core" },
    { "path": "packages/radarr" },
    { "path": "packages/sonarr" },
    { "path": "packages/prowlarr" },
    { "path": "packages/bazarr" },
    { "path": "packages/jellyseerr" },
    { "path": "packages/server" }
  ],
  "files": []
}
